{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TachFileTo",
  "version": "1.0.1",
  "identifier": "com.so-sai.tachfileto",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TachFileTo - Trạm Giám định Hồ sơ",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "copyright": "Copyright © 2026 so-sai/TachFile_To. All rights reserved.",
    "publisher": "so-sai",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}